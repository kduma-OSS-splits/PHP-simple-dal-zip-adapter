{
    "name": "kduma/simple-dal-zip-adapter",
    "description": "Simple DAL - ZIP archive adapter",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "kduma/simple-dal-adapter-contracts": "^0.2",
        "kduma/simple-dal-directory-adapter": "^0.2",
        "league/flysystem": "^3.0",
        "league/flysystem-ziparchive": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "kduma/simple-dal": "^0.2"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Adapter\\Zip\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Adapter\\Zip\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
